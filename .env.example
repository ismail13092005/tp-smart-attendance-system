# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://attendance_user:attendance_pass@localhost:5432/attendance_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT Authentication ────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_min_32_characters_long
JWT_REFRESH_SECRET=your_refresh_secret_min_32_characters_long
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Encryption ────────────────────────────────────────────────────────────────
ENCRYPTION_KEY=your_encryption_key_must_be_32_chars_minimum

# ── Face Recognition Service ──────────────────────────────────────────────────
# Options: mock | aws-rekognition | azure-face
FACE_SERVICE_PROVIDER=mock
FACE_SERVICE_API_KEY=
FACE_SERVICE_ENDPOINT=
FACE_CONFIDENCE_THRESHOLD=0.85
FACE_LIVENESS_ENABLED=false
FACE_ANTI_SPOOFING_ENABLED=false

# AWS Rekognition (required when FACE_SERVICE_PROVIDER=aws-rekognition)
# Install SDK first: npm install @aws-sdk/client-rekognition
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
FACE_AWS_COLLECTION_ID=attendance-faces

# ── QR Code Settings ──────────────────────────────────────────────────────────
QR_TOKEN_EXPIRY_MINUTES=3
QR_SIGNING_SECRET=your_qr_signing_secret_min_32_chars

# ── Geofencing ────────────────────────────────────────────────────────────────
# Uses free Leaflet + OpenStreetMap — no API key required
GEOFENCE_RADIUS_METERS=100
GEOFENCE_ANTI_SPOOFING_ENABLED=false

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ── Email Notifications (optional) ───────────────────────────────────────────
# Install nodemailer first: npm install nodemailer
# If not configured, emails are silently skipped (app never crashes)
EMAIL_PROVIDER=smtp          # Options: smtp | sendgrid
EMAIL_HOST=smtp.gmail.com    # SMTP host (or smtp.sendgrid.net for SendGrid)
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_FROM=noreply@attendance.edu

# ── SMS Notifications (optional) ─────────────────────────────────────────────
# Install twilio first: npm install twilio
# If not configured, SMS is silently skipped (app never crashes)
SMS_PROVIDER=twilio          # Only "twilio" is supported
SMS_API_KEY=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx   # Twilio Account SID
SMS_API_SECRET=your_twilio_auth_token
SMS_FROM_NUMBER=+15551234567  # Your Twilio phone number

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info               # Options: error | warn | info | debug
LOG_FILE_ENABLED=false

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ── File Upload ───────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
UPLOAD_PATH=./uploads

# ── Audit ─────────────────────────────────────────────────────────────────────
AUDIT_RETENTION_DAYS=365

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:4000
